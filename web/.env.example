# Web UI Backend Environment Configuration

# Development Authentication
# REQUIRED: Paste your OIDC ID token here
#
# How to get a working token:
# 1. Run this command to get your current kubectl token:
#    kubectl oidc-login get-token --oidc-issuer-url=<YOUR_DEX_URL> --oidc-client-id=kubectl-oidc --oidc-extra-scope=profile --oidc-extra-scope=groups | jq -r '.status.token'
#
# 2. Or extract it from your kubeconfig:
#    kubectl config view --minify --raw | grep -A 10 "exec:" | grep "oidc-issuer-url" | cut -d'=' -f2
#    Then run: kubectl oidc-login get-token --oidc-issuer-url=<URL> --oidc-client-id=kubectl-oidc --oidc-extra-scope=profile --oidc-extra-scope=groups | jq -r '.status.token'
#
# The token MUST have these claims for proper authentication:
#   - groups: Your GitHub teams/groups (needed for RBAC)
#   - preferred_username: Your GitHub username
#   - name: Your full name
#
# If you paste a token without these claims, you'll get "403 Forbidden" errors.
#
# RBAC Configuration:
# Make sure your GitHub username or team is configured in the Helm chart:
#   guided-charts/aws-traefik-dex/values.yaml → githubRbac section
#
DEV_ACCESS_TOKEN=

# Server Configuration
PORT=8090
NODE_ENV=development

# Kubernetes Configuration
NAMESPACE=default
STATIC_DIR=./dist

# Optional: Development user override (format: "github:username" or "email:user@example.com")
# Only used if you want to override the username extracted from the JWT token
# Leave empty to use the username from the JWT token
DEV_USER=