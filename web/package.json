{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "bun --watch server-bun/index.ts",
    "dev:full": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "tsc -b && vite build",
    "build:server": "echo 'No build needed for Bun server'",
    "build:full": "npm run build && npm run build:server",
    "build:docker": "docker build -t jupyter-k8s-ui .",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "NODE_ENV=production bun run server-bun/index.ts",
    "start:dev": "NODE_ENV=development bun run server-bun/index.ts",
    "docker:build": "docker build -t jupyter-k8s-ui:latest .",
    "docker:run": "docker run -p 8090:8090 jupyter-k8s-ui:latest"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@kubernetes/client-node": "^0.22.0",
    "@tanstack/react-query": "^5.90.12",
    "dotenv": "^17.2.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.469.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bun": "^1.3.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
